#include"ReduceColor.h"
#include <iomanip>

int main(int argc, char* argv[]){
    string file_name = argv[1];
    long seed = atoi(argv[3]);
    srand(seed);

    // 1. 读图
    read_file(file_name);
    long original_edges = edge_count; // 保存初始边数

    // 2. 打表计时
    clock_t dp_start = clock();
    build_reduction(); 
    clock_t dp_end = clock();
    double dp_time = (double)(dp_end - dp_start) / CLOCKS_PER_SEC;

    // 3. 统计核心图结构 (Core Graph)
    long core_nodes = remaining_vertex.size();
    long core_edges = 0;
    for (auto v : remaining_vertex) {
        core_edges += temp_adjacency_list[v].size();
    }
    core_edges /= 2; // 无向图除以2
    
    double original_density = vertex_count > 0 ? (double)original_edges / vertex_count : 0;
    double core_density = core_nodes > 0 ? (double)core_edges / core_nodes : 0;

    // 4. 统计 DP 惩罚空间与数值健康度
    long max_penalty_size = 0;
    long total_penalty_entries = 0;
    long affected_core_nodes = 0;
    long max_penalty_value = 0;

    for (auto v : remaining_vertex) { // 只看存活的核心节点
        long sz = dp_penalty[v].size();
        if (sz > 0) {
            affected_core_nodes++;
            total_penalty_entries += sz;
            if (sz > max_penalty_size) max_penalty_size = sz;
            
            // 扫描找出最大惩罚数值
            for (long p_val : dp_penalty[v]) {
                if (p_val > max_penalty_value) {
                    max_penalty_value = p_val;
                }
            }
        }
    }

    double avg_penalty_size = affected_core_nodes > 0 ? (double)total_penalty_entries / affected_core_nodes : 0;
    double reduce_ratio = vertex_count > 0 ? (double)remove_num / vertex_count * 100.0 : 0;

    // 5. 打印全面诊断报告 (使用制表符方便后续导入 Excel)
    cout << "==== DP Profiling Report ====" << endl;
    cout << "Dataset:       " << file_name << endl;
    cout << "DP Time:       " << fixed << setprecision(4) << dp_time << " s" << endl;
    cout << "-----------------------------------" << endl;
    cout << "[Graph Reduction]" << endl;
    cout << "Original V/E:  " << vertex_count << " / " << original_edges << " (Density: " << fixed << setprecision(2) << original_density << ")" << endl;
    cout << "Core V/E:      " << core_nodes << " / " << core_edges << " (Density: " << fixed << setprecision(2) << core_density << ")" << endl;
    cout << "Removed Nodes: " << remove_num << " (" << fixed << setprecision(2) << reduce_ratio << "%)" << endl;
    cout << "-----------------------------------" << endl;
    cout << "[DP Penalty Space]" << endl;
    cout << "Affected Core: " << affected_core_nodes << " nodes" << endl;
    cout << "Max Pen_Size:  " << max_penalty_size << " colors" << endl;
    cout << "Avg Pen_Size:  " << fixed << setprecision(2) << avg_penalty_size << " colors (per affected node)" << endl;
    cout << "Max Pen_Value: " << max_penalty_value << endl;
    cout << "Forest Score:  " << remove_score << endl;
    cout << "===================================" << endl << endl;

    return 0;
}